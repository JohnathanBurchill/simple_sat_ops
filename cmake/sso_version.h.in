#ifndef SSO_VERSION_H
#define SSO_VERSION_H

#include <stdio.h>
#include <string.h>

#define SSO_VERSION_COMMIT "@SSO_VERSION_COMMIT@"
#define SSO_VERSION_DATE   "@SSO_VERSION_DATE@"
#define SSO_VERSION_DIRTY  "@SSO_VERSION_DIRTY@"

// One-line build version, e.g. "a1b2c3d4e5f6 (2026-06-01)" or
// "...-dirty (...)" when the working tree had uncommitted changes.
static inline const char *sso_version_string(void)
{
    return SSO_VERSION_COMMIT SSO_VERSION_DIRTY " (" SSO_VERSION_DATE ")";
}

// If argv carries -V or --version, print "<prog> <version>" and return 1
// (the caller should then `return 0`). Otherwise return 0. Meant to be the
// first statement of a tool's main(), before its own argument parsing.
static inline int sso_version_handle(int argc, char **argv, const char *prog)
{
    for (int i = 1; i < argc; i++) {
        if (strcmp(argv[i], "-V") == 0 || strcmp(argv[i], "--version") == 0) {
            printf("%s %s\n", prog, sso_version_string());
            return 1;
        }
    }
    return 0;
}

#endif // SSO_VERSION_H
